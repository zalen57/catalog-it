# Salin ke .env — JANGAN commit .env ke Git (sudah di .gitignore)

# Base path GitHub Pages — harus sama dengan GITHUB_PAGES_BASE_PATH di src/config/siteLinks.js
# VITE_BASE_PATH=/catalog-it/

# Domain sintetis untuk akun admin (Firebase butuh format email). Form login hanya isi "User".
# Default di kode: catalog.invalid — override jika perlu, contoh domain Anda sendiri:
# VITE_AUTH_EMAIL_DOMAIN=domainanda.com

# Firebase (Web App config dari Console)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Opsional: Gemini untuk chatbot (batasi key dengan HTTP referrer di Google Cloud)
VITE_GEMINI_API_KEY=
# Default disarankan: gemini-2.5-flash (2.0-flash sering 429 di free tier). Boleh pakai models/gemini-2.5-flash
# VITE_GEMINI_MODEL=gemini-2.5-flash
